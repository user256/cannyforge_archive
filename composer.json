{
    "name": "cannyforge/archive",
    "description": "CannyForge Archive — combined HTML sitemap + JS archive and a crawl-budget-friendly pagination replacement for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "infection/infection": "^0.29",
        "nunomaduro/phpinsights": "^2.11",
        "phparkitect/phparkitect": "^0.4",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.12",
        "phpstan/phpstan-deprecation-rules": "^1.2",
        "phpunit/phpunit": "^9.6",
        "qossmic/deptrac-shim": "^1.0",
        "rector/rector": "^1.2",
        "squizlabs/php_codesniffer": "^3.10",
        "szepeviktor/phpstan-wordpress": "^1.3",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "CannyForge\\Archive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CannyForge\\Archive\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "infection/extension-installer": true
        }
    },
    "scripts": {
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "stan": "phpstan analyse --memory-limit=1G",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "arch": "phparkitect check --config=phparkitect.php",
        "deptrac": "deptrac analyse --config-file=deptrac.yaml --no-progress",
        "mess": "phpmd src,tests text phpmd.xml",
        "insights": "phpinsights analyse --no-interaction",
        "infection": "infection --threads=max --no-progress --no-interaction",
        "test": "phpunit",
        "qa": [
            "@cs",
            "@stan",
            "@rector",
            "@arch",
            "@deptrac",
            "@mess",
            "@test"
        ],
        "review:sim": [
            "@cs",
            "@stan",
            "@rector",
            "@mess",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "cs": "PHPCS / WordPress Coding Standards (gating)",
        "stan": "PHPStan static analysis (high level + dead-code + WP stubs)",
        "rector": "Rector dead-code set, dry-run (zero changes expected)",
        "arch": "PHParkitect architecture rules",
        "deptrac": "Deptrac layer-dependency rules (Core cannot depend on Bootstrap)",
        "mess": "PHPMD — the REAL god-class budget: per-method cyclomatic/length + class size, HARD-FAILS",
        "insights": "PHP Insights — advisory architecture/quality scores only (NOT a gate; PHPMD owns complexity, PHPCS owns style)",
        "infection": "Mutation testing (needs a coverage driver, e.g. pcov — runs in CI; skips locally without one)",
        "qa": "Full quality suite — the merge gate (infection runs separately in CI, needs coverage)",
        "review:sim": "wp.org pre-package review simulation"
    }
}
