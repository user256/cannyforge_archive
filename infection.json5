{
    // Mutation testing config (ticket 604). Infection mutates src/ and re-runs
    // the PHPUnit suite; a mutation that no test catches is an "escaped mutant"
    // and reveals a gap in test strength (coverage % alone lies — a suite can
    // cover a line without asserting its behaviour). The MSI (mutation score
    // indicator) is the real measure.
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ],
        "excludes": [
            // The composition root / bootstrap is mostly WP-hook wiring that the
            // unit suite can't exercise without a WP runtime; mutating it just
            // produces noise. Covered by the integration/strip smoke instead.
            "Bootstrap"
        ]
    },
    "mutators": {
        "@default": true
    },
    "logs": {
        "text": "infection.log"
    },
    // Direct-file guards in the distributable PHP files exit when ABSPATH is not
    // defined. Infection reflects the classes while collecting mutations, so it
    // needs the same bootstrap as PHPUnit to make those classes load safely.
    "bootstrap": "tests/bootstrap.php",
    "testFrameworkOptions": "--order-by=default",
    "minMsi": 48,
    "minCoveredMsi": 55,
    "timeout": 30
}
