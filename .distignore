# Files and directories excluded from the distributable plugin build.
# Used by the deploy step (rsync --exclude-from) so dev/config/docs never ship
# into wp-content/plugins. See ticket 120.

# VCS + env
.git
.gitignore
.gitattributes
.github
.env
.env.*
.agents
.claude

# Dev caches
.phpunit.result.cache
.deptrac.cache
.phpunit.cache

# Tooling configs (not runtime)
composer.json
phpcs.xml.dist
phpstan.neon.dist
phpunit.xml.dist
phpunit.integration.xml.dist
phpmd.xml
rector.php
phparkitect.php
phpinsights.php
infection.json5
deptrac.yaml
composer.lock
package.json
package-lock.json
.wp-env.json

# Tests + docs + project artefacts
vendor
tests
docs
tickets
node_modules
dist
scripts
CannyForge-Archive-Overview.md
README.md
WordPressAudit.md

# Any dev/one-off script at the repo root (e.g. process_tickets.py,
# rebuild_ui.py) — ticket 611: a Python helper leaked into the 0.1.1 ZIP
# because it wasn't covered by name. Excluding the whole extension is more
# robust than chasing individual filenames.
*.py

# wp.org SVN /assets (banner/icon/screenshots) — lives in the SVN assets/
# directory, never inside the plugin's own trunk/tag folder (ticket 610).
.wordpress-org

# This file itself
.distignore
